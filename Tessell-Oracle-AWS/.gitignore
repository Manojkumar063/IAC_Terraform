# Terraform state files (contain passwords in plaintext!)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Sensitive variable files
terraform.tfvars
*.auto.tfvars
*.tfvars.json

# Terraform directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Environment files
.env
.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# HTML documentation files (keep in docs/)
h.html
